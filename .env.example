# Plantilla de entorno local. Copiar a .env (no versionado) y rellenar.
# Ver ADR 0013 (backend de desarrollo) y ADR 0014 (configuracion).
# El valor real nunca se versiona.

# Endpoint OpenAI-compatible del backend de modelos de desarrollo.
OPENAI_COMPAT_BASE_URL=

# Credencial/token del backend, si aplica.
OPENAI_COMPAT_API_KEY=
