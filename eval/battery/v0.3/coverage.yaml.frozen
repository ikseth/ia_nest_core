- id: coverage_out_of_order_acceptance_assembles_order
  track: conformance
  description: "ADR 0038 caso 5: aceptacion desordenada conserva el orden requerido."
  capability: task.run
  fixture: eval/fixtures/orchestration_coverage.yaml
  input:
    prompt: "cubre tres puntos ordenados"
    mode: coverage
    identity: { user_id: u1, service: local_cli }
  world:
    script:
      units:
        - { id: u1, prompt: "primero" }
        - { id: u2, prompt: "segundo" }
        - { id: u3, prompt: "tercero" }
      generator_responses:
        fake_general: [THIRD, FIRST, SECOND]
      validator_decisions:
        - [u3]
        - [u1]
        - [u2]
  expect:
    stop_reason: task_done
    coverage_complete: true
    response: FIRSTSECONDTHIRD
    completed_units: [u1, u2, u3]
    failed_units: []
    pending_units: []
    chunk_index: 3

- id: coverage_domain_hint_per_unit
  track: conformance
  description: "ADR 0038 caso 6: cada domain_hint usa su dominio y modelo declarados."
  capability: task.run
  fixture: eval/fixtures/orchestration_coverage.yaml
  input:
    prompt: "cubre unidades de dominios distintos"
    mode: coverage
    identity: { user_id: u1, service: local_cli }
  world:
    script:
      units:
        - { id: code, prompt: "escribe codigo", domain_hint: codigo }
        - { id: reason, prompt: "razona", domain_hint: razonamiento }
        - { id: general, prompt: "explica", domain_hint: general }
      generator_responses:
        fake_code: [CODE]
        fake_reason: [REASON]
        fake_general: [GENERAL]
      validator_decisions:
        - [code]
        - [reason]
        - [general]
  expect:
    stop_reason: task_done
    coverage_complete: true
    response: CODEREASONGENERAL
    completed_units: [code, reason, general]
    failed_units: []
    pending_units: []
    chunk_index: 3
    units:
      - { id: code, domain: codigo, model: fake_code }
      - { id: reason, domain: razonamiento, model: fake_reason }
      - { id: general, domain: general, model: fake_general }

- id: coverage_dependencies_execute_in_order
  track: conformance
  description: "ADR 0038 caso 9: las unidades depends_on se ejecutan en orden."
  capability: task.run
  fixture: eval/fixtures/orchestration_coverage.yaml
  input:
    prompt: "cubre una cadena dependiente"
    mode: coverage
    identity: { user_id: u1, service: local_cli }
  world:
    script:
      units:
        - { id: u1, prompt: "base" }
        - { id: u2, prompt: "derivada", depends_on: [u1] }
        - { id: u3, prompt: "final", depends_on: [u2] }
      generator_responses:
        fake_general: [ONE, TWO, THREE]
      validator_decisions:
        - [u1]
        - [u2]
        - [u3]
  expect:
    stop_reason: task_done
    coverage_complete: true
    response: ONETWOTHREE
    completed_units: [u1, u2, u3]
    failed_units: []
    pending_units: []
    chunk_index: 3

- id: coverage_no_progress_preserves_partial
  track: conformance
  description: "ADR 0038 caso 10: sin progreso corta no_progress y conserva parcial."
  capability: task.run
  fixture: eval/fixtures/orchestration_coverage.yaml
  input:
    prompt: "cubre dos puntos con uno imposible"
    mode: coverage
    identity: { user_id: u1, service: local_cli }
  world:
    script:
      units:
        - { id: u1, prompt: "punto posible" }
        - { id: u2, prompt: "punto imposible" }
      generator_responses:
        fake_general: [ONE, RETRY_ONE, RETRY_TWO]
      validator_decisions:
        - [u1]
        - []
        - []
  expect:
    stop_reason: no_progress
    coverage_complete: false
    response: ONE
    completed_units: [u1]
    failed_units: [u2]
    pending_units: []
    chunk_index: 3
    max_chunks: 8

- id: coverage_stop_max_chunks
  track: conformance
  description: "ADR 0038 caso 11a: max_chunks no se sobrepasa."
  capability: task.run
  fixture: eval/fixtures/orchestration_coverage.yaml
  input:
    prompt: "cubre diez puntos hasta el limite de chunks"
    mode: coverage
    identity: { user_id: u1, service: local_cli }
  world:
    script:
      units:
        - { id: u1, prompt: "punto 1" }
        - { id: u2, prompt: "punto 2" }
        - { id: u3, prompt: "punto 3" }
        - { id: u4, prompt: "punto 4" }
        - { id: u5, prompt: "punto 5" }
        - { id: u6, prompt: "punto 6" }
        - { id: u7, prompt: "punto 7" }
        - { id: u8, prompt: "punto 8" }
        - { id: u9, prompt: "punto 9" }
        - { id: u10, prompt: "punto 10" }
      generator_responses:
        fake_general: [A, B, C, D, E, F, G, H]
      validator_decisions:
        - [u1]
        - [u2]
        - [u3]
        - [u4]
        - [u5]
        - [u6]
        - [u7]
        - [u8]
  expect:
    stop_reason: max_chunks
    coverage_complete: false
    response: ABCDEFGH
    completed_units: [u1, u2, u3, u4, u5, u6, u7, u8]
    failed_units: []
    pending_units: [u9, u10]
    chunk_index: 8
    max_chunks: 8

- id: coverage_stop_max_time
  track: conformance
  description: "ADR 0038 caso 11b: max_time simulado no se sobrepasa."
  capability: task.run
  fixture: eval/fixtures/orchestration_coverage.yaml
  input:
    prompt: "cubre un punto sin tiempo"
    mode: coverage
    identity: { user_id: u1, service: local_cli }
  world:
    script:
      units:
        - { id: u1, prompt: "punto 1" }
      generator_responses:
        fake_general: [ONE]
      validator_decisions: []
      simulated: { elapsed_s: 31 }
  expect:
    stop_reason: max_time
    coverage_complete: false
    response: ""
    completed_units: []
    failed_units: []
    pending_units: [u1]
    chunk_index: 0
    max_time_s: 30

