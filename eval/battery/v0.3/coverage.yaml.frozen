      units:
        - { id: u1, prompt: "punto 1" }
        - { id: u2, prompt: "punto 2" }
        - { id: u3, prompt: "punto 3" }
        - { id: u4, prompt: "punto 4" }
      generator_responses:
        fake_general: [FIRST, LAST]
      validator_decisions:
        - [u1, u2, u3]
        - [u1, u4]
  expect:
    stop_reason: task_done
    coverage_complete: true
    response: FIRSTLAST
    completed_units: [u1, u2, u3, u4]
    failed_units: []
