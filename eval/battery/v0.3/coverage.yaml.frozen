# Bateria de task.run mode=coverage (linea v0.3, ADR 0038). CRITERIO DE
# ACEPTACION escrito y CONGELADO ANTES de implementar (fase v0.3-2 del PLAN).
# El runner NO carga este archivo hasta la fase v0.3-2.
#
# Scripting determinista (world.script), realizado por ScriptedFakeAdapter en
# la implementacion v0.3-2:
# - units: lista que el fake planner deriva en DERIVE. Cada unidad es
#   {id, prompt, domain_hint (opcional), depends_on (opcional, ids)}.
# - generator_responses: por modelo fake, lista de fragmentos en el orden de
#   llamada de generacion.
# - generator_finish_reasons: por modelo fake, lista opcional de
#   finish_reason por llamada; el valor por defecto es stop y permite length.
# - validator_decisions: una lista, una entrada por llamada de validacion,
#   con los ids aceptados. Puede aceptar menos de lo pedido, repetir ids ya
#   aceptados (se ignoran) o no aceptar ninguno.
# - simulated: agotamiento simulado {elapsed_s | context_tokens}, sin reloj
#   real, como en la bateria v0.2. En modo coverage, context_tokens override
#   el acumulado real que gobierna max_total_tokens (precedencia de la ficha
#   v0.2/0003).
#
# Semantica congelada del bucle (fijada en revision, vinculante para la
# implementacion v0.3-2):
# - chunk_index cuenta LLAMADAS de generacion, acepten o no unidades; es el
#   contador que gobierna max_chunks (guardia anti-bucle del ADR 0038).
# - retries por unidad: una unidad objetivo de una llamada cuyo fragmento no
#   la cubre suma 1 intento fallido; pasa a failed al acumular
#   1 + max_retries_per_unit intentos fallidos (intento inicial mas
#   max_retries_per_unit reintentos).
# - los cortes (max_chunks, max_time, max_total_tokens, no_progress) se
#   evaluan ANTES de cada ciclo de generacion, incluido el primero.
# - las llamadas de validacion siguen orden determinista (orden de las
#   unidades en el plan), aunque la generacion de grupos independientes sea
#   paralela; validator_decisions se consume en ese orden.

- id: coverage_ten_units_three_per_chunk
  track: conformance
  description: "ADR 0038 caso 1: diez unidades a tres por llamada terminan todas."
  capability: task.run
  fixture: eval/fixtures/orchestration_coverage.yaml
  input:
    prompt: "cubre diez puntos"
    mode: coverage
    identity: { user_id: u1, service: local_cli }
  world:
    script:
      units:
        - { id: u01, prompt: "punto 1" }
        - { id: u02, prompt: "punto 2" }
        - { id: u03, prompt: "punto 3" }
        - { id: u04, prompt: "punto 4" }
        - { id: u05, prompt: "punto 5" }
        - { id: u06, prompt: "punto 6" }
        - { id: u07, prompt: "punto 7" }
        - { id: u08, prompt: "punto 8" }
        - { id: u09, prompt: "punto 9" }
        - { id: u10, prompt: "punto 10" }
      generator_responses:
        fake_general: [A, B, C, D]
      validator_decisions:
        - [u01, u02, u03]
        - [u04, u05, u06]
        - [u07, u08, u09]
        - [u10]
  expect:
    stop_reason: task_done
    coverage_complete: true
    response: ABCD
    completed_units: [u01, u02, u03, u04, u05, u06, u07, u08, u09, u10]
    failed_units: []
    pending_units: []
    chunk_index: 4
    max_chunks: 8
    max_total_tokens: 16384

- id: coverage_stop_continues_pending
  track: conformance
  description: "ADR 0038 caso 2: stop tecnico con cobertura incompleta continua."
  capability: task.run
  fixture: eval/fixtures/orchestration_coverage.yaml
  input:
    prompt: "cubre cuatro puntos"
    mode: coverage
    identity: { user_id: u1, service: local_cli }
  world:
    script:
      units:
        - { id: u1, prompt: "punto 1" }
        - { id: u2, prompt: "punto 2" }
        - { id: u3, prompt: "punto 3" }
        - { id: u4, prompt: "punto 4" }
      generator_responses:
        fake_general: [FIRST, LAST]
      generator_finish_reasons:
        fake_general: [stop, stop]
      validator_decisions:
        - [u1, u2, u3]
        - [u4]
  expect:
    stop_reason: task_done
    coverage_complete: true
    response: FIRSTLAST
    completed_units: [u1, u2, u3, u4]
    failed_units: []
    pending_units: []
    chunk_index: 2

- id: coverage_length_continues_pending
  track: conformance
  description: "ADR 0038 caso 3: length continua desde pendientes sin duplicar respuesta."
  capability: task.run
  fixture: eval/fixtures/orchestration_coverage.yaml
  input:
    prompt: "cubre cuatro puntos con corte tecnico"
    mode: coverage
    identity: { user_id: u1, service: local_cli }
  world:
    script:
      units:
        - { id: u1, prompt: "punto 1" }
        - { id: u2, prompt: "punto 2" }
        - { id: u3, prompt: "punto 3" }
        - { id: u4, prompt: "punto 4" }
      generator_responses:
        fake_general: [FIRST, LAST]
      generator_finish_reasons:
        fake_general: [length, stop]
      validator_decisions:
        - [u1, u2, u3]
        - [u4]
  expect:
    stop_reason: task_done
    coverage_complete: true
    response: FIRSTLAST
    completed_units: [u1, u2, u3, u4]
    failed_units: []
    pending_units: []
    chunk_index: 2

- id: coverage_repeated_validator_id_ignored
